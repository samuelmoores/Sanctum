@{
    ViewData["Title"] = "Book a Room";
}

<div class="booking-page-container">
    <section class="booking-hero">
        <div class="booking-hero-content">
            <div class="booking-hero-text">
                <h1 class="booking-title">CSULB Room Booking</h1>
                <p class="booking-subtitle">
                    Select a building, choose a room, pick a date, and reserve an available time.
                </p>
            </div>

            <div class="profile-menu-wrapper">
                <button id="profileMenuBtn" class="profile-menu-btn" type="button" aria-label="Profile menu">
                    <span class="profile-icon-head"></span>
                    <span class="profile-icon-body"></span>
                </button>

                <div id="profileDropdown" class="profile-dropdown">
                    <button type="button" id="viewBookingsBtn" class="profile-dropdown-item profile-dropdown-button">
                        View My Bookings
                    </button>
                    <a href="/" class="profile-dropdown-item">Sign Out</a>
                </div>
            </div>
        </div>
    </section>

    <section class="booking-dashboard">
        <!-- LEFT: MAP -->
        <div class="booking-widget map-widget">
            <div class="widget-header">
                <h2>Campus Map</h2>
                <span id="selectedBuildingBadge" class="widget-badge">No building selected</span>
            </div>

            <div class="map-area">
                <img src="~/images/map.png" alt="CSULB Campus Map" class="campus-map-img" />

                <button class="building-pin" style="top: 34%; left: 12%;" data-building="COB">COB</button>
                <button class="building-pin" style="top: 48%; left: 72%;" data-building="VEC">VEC</button>
                <button class="building-pin" style="top: 43%; left: 33%;" data-building="HC">HC</button>
                <button class="building-pin" style="top: 97%; left: 47%;" data-building="SSSC">SSSC</button>
            </div>
        </div>

        <!-- ROOMS -->
        <div class="booking-widget rooms-widget">
            <div class="widget-header">
                <h2>Select a Room</h2>
            </div>

            <div id="roomList" class="room-list">
                <p class="placeholder-text">Choose a building first to view available rooms.</p>
            </div>
        </div>

        <!-- CALENDAR -->
        <div class="booking-widget calendar-widget">
            <div class="widget-header">
                <h2>Select a Date</h2>
            </div>

            <div class="calendar-topbar">
                <button id="prevMonthBtn" class="calendar-nav-btn">&lt;</button>
                <h3 id="calendarMonthYear"></h3>
                <button id="nextMonthBtn" class="calendar-nav-btn">&gt;</button>
            </div>

            <div class="calendar-grid calendar-days">
                <div>Sun</div>
                <div>Mon</div>
                <div>Tue</div>
                <div>Wed</div>
                <div>Thu</div>
                <div>Fri</div>
                <div>Sat</div>
            </div>

            <div id="calendarDates" class="calendar-grid calendar-dates"></div>
        </div>

        <!-- TIMES + SUMMARY -->
        <div class="booking-widget times-widget">
            <div class="widget-header">
                <h2>Available Times</h2>
            </div>

            <div id="timeSlots" class="time-slots">
                <p class="placeholder-text">Choose a building, room, and date to see available times.</p>
            </div>

            <div class="booking-summary-card">
                <h3>Booking Summary</h3>
                <div class="summary-row">
                    <span>Building</span>
                    <strong id="summaryBuilding">—</strong>
                </div>
                <div class="summary-row">
                    <span>Room</span>
                    <strong id="summaryRoom">—</strong>
                </div>
                <div class="summary-row">
                    <span>Date</span>
                    <strong id="summaryDate">—</strong>
                </div>
                <div class="summary-row">
                    <span>Time</span>
                    <strong id="summaryTime">—</strong>
                </div>

                <button id="confirmBookingBtn" class="confirm-booking-btn">
                    Confirm Booking
                </button>
            </div>
        </div>
    </section>

        <!-- MY BOOKINGS POPUP -->
        <div id="bookingsModalOverlay" class="modal-overlay">
            <div class="modal-widget bookings-modal">
                <div class="modal-header">
                    <div>
                        <h2>My Bookings</h2>
                        <p class="modal-greeting">Hi, @ViewBag.UserName</p>
                    </div>

                    <button type="button" id="closeBookingsModalBtn" class="modal-close-btn">&times;</button>
                </div>

                <div class="modal-body">
                    <div id="bookingHistoryList" class="booking-history-list">
                        <p class="empty-bookings-text">Loading your bookings...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

// JavaScript for handling the confirm booking button click and sending data to the server
// This script should be placed at the bottom of the page to ensure all elements are loaded before it runs
@section Scripts {
    <script>
        // Getting the confirm button (from Times + summary)
        const confirmBtn = document.getElementById('confirmBookingBtn');

        // Action when the confirm button is clicked by the User
        confirmBtn.addEventListener('click', function() {
            // Get the values listed in the summary card
            const building = document.getElementById('summaryBuilding').innerText;
            const room = document.getElementById('summaryRoom').innerText;
            const date = document.getElementById('summaryDate').innerText;
            const time = document.getElementById('summaryTime').innerText;

            // Send it to the server (URL of C# endpoint)
            fetch('/Booking/ConfirmBooking', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                //Actual data being sent to the server
                body: `building=${building}&room=${room}&date=${date}&time=${time}`
            })

            .then(response => response.json())
            .then(data => {
                // Alert the user if the booking was successful or if there was an error
                // Might be redundant since the before this is already a confirmation popup
                if (data.success) {
                    alert('Booking confirmed!');
                }
                else {
                    alert('Error confirming booking: ' + data.message);
                }
            });
        });
        </script>

    }