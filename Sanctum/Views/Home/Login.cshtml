@{
    ViewData["Title"] = "Login Page";
}

<div style="display:flex; align-items:flex-start; padding: 12px 0 10px 24px;">
    <a asp-controller="Home" asp-action="Index" class="nav-back-btn" title="Back to Home">&#8592;</a>
</div>
<div class="text-center">
    <h3 style="margin-top: 10px;"></h3>
    <h1 class="display-4">Login</h1>
    <h3 style="margin-top: 30px;"></h3>

    <form method="post" action="/Home/Login" style="display: inline-block; text-align: left;">
        <div style="display: flex; align-items: center; margin-bottom: 10px;">
            <label style="width: 90px; margin-right: 10px;">Username</label>
            <input type="text" name="Username" class="auth-input" />
        </div>
        <div style="display: flex; align-items: center; margin-bottom: 4px;">
            <label style="width: 90px; margin-right: 10px;">Password</label>
            <input type="password" name="Password" class="auth-input" />
        </div>
        <div style="display: flex; margin-bottom: 10px;">
            <span style="width: 90px; margin-right: 10px;"></span>
            <a asp-controller="Home" asp-action="ResetPassword" style="font-size:0.8rem; color:#3b82f6; text-decoration:underline; cursor:pointer; transition: color 0.15s;">Forgot Password?</a>
        </div>
        <div style="text-align: center; margin-top: 10px;">
            <button type="submit" class="login-btn">Login</button>
        </div>
        <div style="text-align: center; margin-top: 10px;">
            @if (ViewBag.alert != null)
            {
                    <div class="alert alert-danger" role="alert">
                        @ViewBag.alert
                    </div>
            }
        </div>
    </form>

</div>
